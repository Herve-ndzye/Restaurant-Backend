# Database Configuration
DB_HOST=localhost
DB_PORT=3000
DB_NAME=restaurant
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_generate_with_openssl_rand_base64_64
JWT_EXPIRATION=86400000

# Application Configuration
SHOW_SQL=false
SPRING_PROFILES_ACTIVE=prod

# Server Configuration
SERVER_PORT=8080

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting (configured in code)
# AUTH_RATE_LIMIT=5 requests per minute
# GENERAL_RATE_LIMIT=20 requests per minute

# Account Lockout (configured in code)
# MAX_FAILED_ATTEMPTS=5
# LOCKOUT_DURATION_MINUTES=15
